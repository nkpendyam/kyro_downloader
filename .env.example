# Kyro Downloader — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore

# --- Download defaults ---
KYRO_DOWNLOAD_DIR=~/Downloads/Kyro
KYRO_CONCURRENT_WORKERS=4
KYRO_RATE_LIMIT=0
# Rate limit in bytes/sec (0 = unlimited). Example: 1M, 500K

# --- Proxy (optional) ---
KYRO_PROXY=
# Format: http://user:pass@host:port or socks5://host:port

# --- Web UI ---
KYRO_WEB_HOST=127.0.0.1
KYRO_WEB_PORT=8000
KYRO_WEB_SECRET_KEY=change-this-to-a-random-secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# --- SponsorBlock ---
KYRO_SPONSORBLOCK_ENABLED=false
KYRO_SPONSORBLOCK_CATEGORIES=sponsor,intro,outro

# --- Notifications ---
KYRO_NOTIFICATIONS_ENABLED=true

# --- Logging ---
KYRO_LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# --- yt-dlp ---
KYRO_YTDLP_VERBOSE=false
KYRO_YTDLP_AUTO_UPDATE=true

# --- Cloud upload (optional) ---
# Only needed if using cloud_upload.py service
KYRO_S3_BUCKET=
KYRO_S3_ACCESS_KEY=
KYRO_S3_SECRET_KEY=
KYRO_S3_REGION=
