block_cipher = None

a = Analysis(
    ['src/gui/gui_main.py'],
    pathex=[],
    binaries=[],
    datas=[
        ('config', 'config'),
    ],
    hiddenimports=[
        # Core
        'src',
        'src.core',
        'src.core.downloader',
        'src.core.download_manager',
        'src.core.queue',
        'src.core.progress',
        'src.core.retry',
        'src.core.concurrent',
        # Services
        'src.services',
        'src.services.archive',
        'src.services.channels',
        'src.services.chapters',
        'src.services.cloud_upload',
        'src.services.compressor',
        'src.services.converter',
        'src.services.cookies_from_browser',
        'src.services.date_filter',
        'src.services.external_dl',
        'src.services.filesize_filter',
        'src.services.format_sorter',
        'src.services.geo_restriction',
        'src.services.impersonation',
        'src.services.info_json',
        'src.services.livestream',
        'src.services.match_filter',
        'src.services.media_server',
        'src.services.metadata',
        'src.services.netrc_auth',
        'src.services.output_template',
        'src.services.scheduler',
        'src.services.search',
        'src.services.sponsorblock',
        'src.services.statistics',
        'src.services.subtitles',
        'src.services.thumbnails',
        'src.services.trimming',
        'src.services.watch_later',
        # Utils
        'src.utils',
        'src.utils.ytdlp_updater',
        'src.utils.app_updater',
        'src.utils.circuit_breaker',
        'src.utils.dedup',
        'src.utils.ffmpeg',
        'src.utils.logger',
        'src.utils.notifications',
        'src.utils.platform',
        'src.utils.url_expander',
        'src.utils.validation',
        # Config
        'src.config',
        'src.config.defaults',
        'src.config.manager',
        'src.config.schema',
        # GUI
        'src.gui',
        'src.gui.app',
        'src.gui.gui_main',
        # CLI commands (imported dynamically)
        'src.cli',
        'src.cli.__main__',
        'src.cli.commands',
        'src.cli.commands.archive',
        'src.cli.commands.channels',
        'src.cli.commands.chapters',
        'src.cli.commands.compress',
        'src.cli.commands.convert',
        'src.cli.commands.external',
        'src.cli.commands.livestream',
        'src.cli.commands.schedule',
        'src.cli.commands.search',
        'src.cli.commands.stats',
