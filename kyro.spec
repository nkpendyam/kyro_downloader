# -*- mode: python ; coding: utf-8 -*-
"""PyInstaller spec file for Kyro Downloader - Windows EXE.

Uses CustomTkinter for GUI - no runtime binary downloads required.
Everything is bundled in the EXE for reliable distribution.
"""
