        'src.ui',
        'src.ui.banner',
        'src.ui.themes',
        'src.ui.tui',
        'src.ui.web',
        'src.ui.web.server',
        'src.ui.web.routes',
        'src.ui.web.websocket',
        # Plugins
        'src.plugins',
        'src.plugins.builtin',
        'src.plugins.builtin.auto_compress',
        'src.plugins.builtin.auto_convert',
        'src.plugins.builtin.auto_organize',
        'src.plugins.builtin.auto_thumbnail',
        'src.plugins.builtin.subtitle_auto',
        # Third-party
        'customtkinter',
        'darkdetect',
